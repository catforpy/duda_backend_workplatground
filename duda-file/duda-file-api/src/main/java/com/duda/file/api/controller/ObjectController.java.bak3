    /**
     * 列出目录内容
     *
     * 列出指定目录下的文件和子目录。
     *
     * @param bucketName Bucket 名称
     * @param prefix 目录前缀
     * @param delimiter 分隔符（通常为 "/"）
     * @param maxKeys 最大返回数量
     * @return 目录内容列表
     */
    @Operation(summary = "列出目录内容", description = "列出指定目录下的文件和子目录")
    @GetMapping("/list")
    public Result listDirectoryContents(
        @Parameter(description = "Bucket名称", required = true)
        @RequestParam String bucketName,
        @Parameter(description = "目录前缀")
        @RequestParam(required = "") String prefix,
        @Parameter(description = "分隔符")
        @RequestParam(defaultValue = "/") String delimiter,
        @Parameter(description = "最大返回数量")
        @RequestParam(defaultValue = "100") Integer maxKeys) {

        ListObjectsReqDTO request = ListObjectsReqDTO.builder()
            .bucketName(bucketName)
            .prefix(prefix)
            .delimiter(delimiter)
            .maxKeys(maxKeys)
            .build();

        ListObjectsResultDTO result = objectService.listObjects(request);

        return Result.success(result);
    }

