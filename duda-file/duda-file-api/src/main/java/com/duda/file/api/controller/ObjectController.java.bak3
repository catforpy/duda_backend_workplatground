        @RequestParam Long userId) {

        // 确保目录路径以 "/" 结尾
        if (!directoryPath.endsWith("/")) {
            directoryPath += "/";
        }

        // TODO: 实现目录创建逻辑
        // objectService.createDirectory(bucketName, directoryPath, userId);

        return Result.success(null, "目录创建成功");
