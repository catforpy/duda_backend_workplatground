    @GetMapping("/search")
    public Result searchObjects(
        @Parameter(description = "Bucket名称", required = true)
        @RequestParam String bucketName,
        @Parameter(description = "搜索前缀", required = true)
        @RequestParam String prefix,
        @Parameter(description = "最大返回数量")
        @RequestParam(defaultValue = "100") Integer maxKeys) {

        List<ObjectDTO> results = objectService.listObjectsRecursive(bucketName, prefix, maxKeys);

        return Result.success(results);
    }

    // ==================== 权限管理 API ====================

    /**
     * 设置文件 ACL
     *
     * 设置对象的访问控制列表。
     *
     * @param bucketName Bucket 名称
     * @param objectKey 对象键
     * @param aclType ACL 类型
     * @return 设置结果
     */
    @Operation(summary = "设置文件ACL", description = "设置对象的访问权限")
    @PutMapping("/acl")
    public Result setObjectAcl(
        @Parameter(description = "Bucket名称", required = true)
        @RequestParam String bucketName,
        @Parameter(description = "对象键", required = true)
        @RequestParam String objectKey,
        @Parameter(description = "ACL类型", required = true)
        @RequestParam com.duda.file.enums.AclType aclType) {

        objectService.setObjectAcl(bucketName, objectKey, aclType);

        return Result.success(null, "ACL 设置成功");
    }

