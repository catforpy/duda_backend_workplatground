<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.duda.file.provider.mapper.BucketBillingConfigMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.duda.file.provider.entity.BucketBillingConfig">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="bucket_name" property="bucketName" jdbcType="VARCHAR"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="tenant_id" property="tenantId" jdbcType="BIGINT"/>
        <result column="billing_cycle" property="billingCycle" jdbcType="VARCHAR"/>
        <result column="unit_price" property="unitPrice" jdbcType="DECIMAL"/>
        <result column="traffic_unit_price" property="trafficUnitPrice" jdbcType="DECIMAL"/>
        <result column="free_quota" property="freeQuota" jdbcType="BIGINT"/>
        <result column="low_balance_threshold" property="lowBalanceThreshold" jdbcType="DECIMAL"/>
        <result column="quota_warning_threshold" property="quotaWarningThreshold" jdbcType="INTEGER"/>
        <result column="overdraft_allowed" property="overdraftAllowed" jdbcType="TINYINT"/>
        <result column="max_overdraft" property="maxOverdraft" jdbcType="DECIMAL"/>
        <result column="notification_enabled" property="notificationEnabled" jdbcType="TINYINT"/>
        <result column="notification_email" property="notificationEmail" jdbcType="VARCHAR"/>
        <result column="notification_mobile" property="notificationMobile" jdbcType="VARCHAR"/>
        <result column="webhook_url" property="webhookUrl" jdbcType="VARCHAR"/>
        <result column="balance" property="balance" jdbcType="DECIMAL"/>
        <result column="status" property="status" jdbcType="VARCHAR"/>
        <result column="suspend_reason" property="suspendReason" jdbcType="VARCHAR"/>
        <result column="created_by" property="createdBy" jdbcType="BIGINT"/>
        <result column="created_time" property="createdTime" jdbcType="TIMESTAMP"/>
        <result column="updated_by" property="updatedBy" jdbcType="BIGINT"/>
        <result column="updated_time" property="updatedTime" jdbcType="TIMESTAMP"/>
        <result column="is_deleted" property="isDeleted" jdbcType="TINYINT"/>
    </resultMap>

    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, bucket_name, user_id, tenant_id, billing_cycle, unit_price, traffic_unit_price, free_quota,
        low_balance_threshold, quota_warning_threshold, overdraft_allowed, max_overdraft,
        notification_enabled, notification_email, notification_mobile, webhook_url,
        balance, status, suspend_reason, created_by, created_time, updated_by, updated_time, is_deleted
    </sql>

    <!-- 根据Bucket名称查询 -->
    <select id="selectByBucketName" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM bucket_billing_config
        WHERE bucket_name = #{bucketName}
        AND is_deleted = 0
    </select>

    <!-- 根据用户ID查询列表 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM bucket_billing_config
        WHERE user_id = #{userId}
        AND is_deleted = 0
        ORDER BY created_time DESC
    </select>

    <!-- 更新余额 -->
    <update id="updateBalance">
        UPDATE bucket_billing_config
        SET balance = balance + #{amount},
            updated_time = NOW()
        WHERE bucket_name = #{bucketName}
    </update>

    <!-- 更新状态 -->
    <update id="updateStatus">
        UPDATE bucket_billing_config
        SET status = #{status},
            suspend_reason = #{reason},
            updated_time = NOW()
        WHERE bucket_name = #{bucketName}
    </update>

</mapper>
