# 阿里云OSS配置
# 请将此文件复制为 .env 并填写真实的值
# OSS访问密钥ID
OSS_ACCESS_KEY_ID=your-access-key-id
# OSS访问密钥Secret
OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS STS Role ARN（用于获取临时凭证）
OSS_STS_ROLE_arn=acs:ram::your-account-id:role/your-sts-role-name
# OSS区域（默认：cn-hangzhou）
OSS_REGION=cn-hangzhou
# OSS Bucket名称（默认：duda-java-backend-test）
OSS_BUCKET=duda-java-backend-test
