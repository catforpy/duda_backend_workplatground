#### 3.5.6 PHP后端调用示例

**完整示例1：用户登录场景**

```php
<?php

namespace App\Services;

use Illuminate\Support\Facades\Http;
use Illuminate\Support\Facades\Log;

class DudaNexusApiClient
{
    protected $baseUrl = 'https://api.dudanexus.com/b2b/v1';
    protected $appId;
    protected $appSecret;

    public function __construct()
    {
        $this->appId = config('dudanexus.app_id');
        $this->appSecret = config('dudanexus.app_secret');
    }

    /**
     * 生成签名
     */
    private function generateSignature($timestamp, $nonce)
    {
        $params = [
            'app_id=' . $this->appId,
            'nonce=' . $nonce,
            'timestamp=' . $timestamp,
        ];
        sort($params);
        $signStr = implode('&', $params) . '&app_secret=' . $this->appSecret;
        return strtoupper(md5($signStr));
    }

    /**
     * 发起API请求
     */
    private function request($url, $data = [])
    {
        $timestamp = time();
        $nonce = Str::random(8);
        $signature = $this->generateSignature($timestamp, $nonce);

        $response = Http::withHeaders([
            'X-App-Id' => $this->appId,
            'X-Timestamp' => $timestamp,
            'X-Nonce' => $nonce,
            'X-Signature' => $signature,
        ])->post($this->baseUrl . $url, $data);

        $result = $response->json();

        if ($result['code'] !== 200) {
            Log::error('DudaNexus API调用失败', [
                'url' => $url,
                'response' => $result,
            ]);
            throw new \Exception($result['message']);
        }

        return $result['data'];
    }

    /**
     * 用户登录流程
     */
    public function userLogin($phone)
    {
        // Step 1: 检查手机号是否已在Java后端注册
        $checkResult = $this->checkPhone($phone);

        if ($checkResult['exists']) {
            // Step 2a: 手机号已注册，获取UnionID
            $platformUnionid = $checkResult['platform_unionid'];

            // Step 3a: 查询用户信息
            $userInfo = $this->getUserInfo('unionid', $platformUnionid);

            // Step 4a: 绑定PHP后端用户ID（如果还没绑定）
            $this->bindAccount($phone, $platformUnionid);

            return [
                'exists' => true,
                'user_info' => $userInfo,
            ];
        } else {
            // Step 2b: 手机号未注册，创建新用户并分配UnionID
            $platformUnionid = $this->allocateUnionid($phone);

            return [
                'exists' => false,
                'platform_unionid' => $platformUnionid,
            ];
        }
    }

    /**
     * 检查手机号是否已注册
     */
    public function checkPhone($phone)
    {
        return $this->request('/auth/check-phone', [
            'phone' => $phone,
        ]);
    }

    /**
     * 获取用户信息
     */
    public function getUserInfo($queryType, $queryValue)
    {
        return $this->request('/user/info', [
            'query_type' => $queryType,
            'query_value' => $queryValue,
        ]);
    }

    /**
     * 绑定账户
     */
    public function bindAccount($phone, $platformUnionid)
    {
        $phpUserId = auth()->user()->id;

        return $this->request('/auth/bind-account', [
            'phone' => $phone,
            'backend_system' => 'php',
            'backend_user_id' => $phpUserId,
            'backend_user_shard' => 0,
        ]);
    }

    /**
     * 查询用户订单列表
     */
    public function getUserOrders($platformUnionid, $page = 1, $pageSize = 20)
    {
        return $this->request('/order/list', [
            'unionid' => $platformUnionid,
            'page' => $page,
            'page_size' => $pageSize,
        ]);
    }

    /**
     * 查询订单详情
     */
    public function getOrderDetail($orderId)
    {
        return $this->request('/order/detail', [
            'order_id' => $orderId,
        ]);
    }
}
```

**Laravel控制器中使用**：

```php
<?php

namespace App\Http\Controllers;

use App\Services\DudaNexusApiClient;
use Illuminate\Http\Request;

class UserController extends Controller
{
    protected $apiClient;

    public function __construct(DudaNexusApiClient $apiClient)
    {
        $this->apiClient = $apiClient;
    }

    /**
     * 用户登录
     */
    public function login(Request $request)
    {
        $phone = $request->input('phone');

        try {
            // 调用Java后端API
            $result = $this->apiClient->userLogin($phone);

            if ($result['exists']) {
                // 用户已存在，直接登录
                $userInfo = $result['user_info'];
                // ... 本地登录逻辑
            } else {
                // 新用户，创建本地账户
                $platformUnionid = $result['platform_unionid'];
                // ... 创建本地用户逻辑
            }

            return response()->json([
                'code' => 200,
                'message' => '登录成功',
            ]);
        } catch (\Exception $e) {
            return response()->json([
                'code' => 500,
                'message' => '登录失败：' . $e->getMessage(),
            ]);
        }
    }

    /**
     * 查看我的订单
     */
    public function myOrders(Request $request)
    {
        $page = $request->input('page', 1);
        $platformUnionid = auth()->user()->platform_unionid;

        try {
            $orders = $this->apiClient->getUserOrders($platformUnionid, $page);

            return response()->json([
                'code' => 200,
                'message' => 'success',
                'data' => $orders,
            ]);
        } catch (\Exception $e) {
            return response()->json([
                'code' => 500,
                'message' => '查询失败：' . $e->getMessage(),
            ]);
        }
    }
}
```

**完整示例2：查询订单场景**

```php
<?php

namespace App\Jobs;

use App\Services\DudaNexusApiClient;
use Illuminate\Bus\Queueable;
use Illuminate\Contracts\Queue\ShouldQueue;
use Illuminate\Queue\InteractsWithQueue;
use Illuminate\Queue\SerializesModels;

class SyncUserOrdersFromJava implements ShouldQueue
{
    use InteractsWithQueue, Queueable, SerializesModels;

    protected $platformUnionid;

    public function __construct($platformUnionid)
    {
        $this->platformUnionid = $platformUnionid;
    }

    public function handle(DudaNexusApiClient $apiClient)
    {
        $page = 1;
        $pageSize = 100;
        $hasMore = true;

        while ($hasMore) {
            // 调用Java后端API
            $result = $apiClient->getUserOrders($this->platformUnionid, $page, $pageSize);

            // 批量同步到本地数据库
            foreach ($result['orders'] as $order) {
                \App\Models\Order::updateOrCreate(
                    ['order_id' => $order['order_id']],
                    [
                        'merchant_id' => $order['merchant_id'],
                        'order_amount' => $order['order_amount'],
                        'pay_amount' => $order['pay_amount'],
                        'order_status' => $order['order_status'],
                        'order_time' => $order['order_time'],
                    ]
                );
            }

            // 判断是否还有更多数据
            $total = $result['total'];
            $hasMore = $page * $pageSize < $total;
            $page++;
        }
    }
}
```

