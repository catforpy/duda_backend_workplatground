    - active: 正常
    - frozen: 冻结
    - banned: 封禁
    - deleted: 已删除',
  `status_reason` VARCHAR(500) COMMENT '状态变更原因',

  -- ========== 注册信息 ==========
  `register_source` VARCHAR(50) COMMENT '注册来源：
    - mini_program: 小程序注册
    - h5: H5页面注册
    - api: API注册
    - backend: 后台添加',
  `register_channel` VARCHAR(100) COMMENT '注册渠道（具体小程序或商户ID）',
  `register_ip` VARCHAR(50) COMMENT '注册IP地址',
  `register_time` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '注册时间',

  -- ========== 最后登录信息 ==========
  `last_login_time` DATETIME COMMENT '最后登录时间',
  `last_login_ip` VARCHAR(50) COMMENT '最后登录IP',
  `last_login_device` VARCHAR(200) COMMENT '最后登录设备信息',

  -- ========== 统计信息 ==========
  `login_count` INT DEFAULT 0 COMMENT '累计登录次数',
  `merchant_count` INT DEFAULT 0 COMMENT '关联商户数量（虚拟用户数）',
  `total_order_count` INT DEFAULT 0 COMMENT '累计订单数（跨商户汇总）',
  `total_consume_amount` DECIMAL(12,2) DEFAULT 0.00 COMMENT '累计消费金额（跨商户汇总）',

  -- ========== 时间信息 ==========
  `create_time` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `update_time` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',

  PRIMARY KEY (`user_id`),
  UNIQUE KEY `uk_phone` (`phone`),
  UNIQUE KEY `uk_wechat_unionid` (`wechat_unionid`),
  KEY `idx_account_status` (`account_status`),
  KEY `idx_user_type` (`user_type`),
  KEY `idx_register_time` (`register_time`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='平台用户表（分片00）';

-- 说明：
-- 1. users_01 到 users_15 表结构与 users_00 完全相同
-- 2. 分片规则：table_index = user_id % 16
-- 3. 例如：user_id = 5032850826727424，则在 users_00 表（5032850826727424 % 16 = 0）
```

**分片查询示例**：
```java
// Java代码示例：根据user_id查询用户
public User getUserById(Long userId) {
    int tableIndex = (int) (userId % 16);
    String tableName = "users_" + String.format("%02d", tableIndex);
    String sql = "SELECT * FROM " + tableName + " WHERE user_id = ?";
    return jdbcTemplate.queryForObject(sql, User.class, userId);
}

// 根据手机号查询（需要查询所有分片）
public User getUserByPhone(String phone) {
    for (int i = 0; i < 16; i++) {
        String tableName = "users_" + String.format("%02d", i);
        try {
            User user = jdbcTemplate.queryForObject(
                "SELECT * FROM " + tableName + " WHERE phone = ?",
                User.class, phone
            );
            if (user != null) return user;
        } catch (EmptyResultDataAccessException e) {
            // 继续查询下一张表
        }
    }
    return null;
}
```

