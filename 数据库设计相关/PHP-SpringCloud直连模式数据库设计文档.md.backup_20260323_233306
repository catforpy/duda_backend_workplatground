    - daily: 日结
    - weekly: 周结
    - monthly: 月结',
  `start_date` DATE NOT NULL COMMENT '结算开始日期',
  `end_date` DATE NOT NULL COMMENT '结算结束日期',

  -- ========== 订单统计 ==========
  `total_orders` INT DEFAULT 0 COMMENT '订单总数',
  `total_amount` DECIMAL(12,2) DEFAULT 0.00 COMMENT '订单总金额',
  `paid_amount` DECIMAL(12,2) DEFAULT 0.00 COMMENT '实付金额',
  `refunded_amount` DECIMAL(12,2) DEFAULT 0.00 COMMENT '退款金额',

  -- ========== 分账统计 ==========
  `platform_share_amount` DECIMAL(12,2) DEFAULT 0.00 COMMENT '平台抽成金额',
  `service_provider_share_amount` DECIMAL(12,2) DEFAULT 0.00 COMMENT '服务商抽成金额',
  `merchant_income_amount` DECIMAL(12,2) DEFAULT 0.00 COMMENT '商户收入金额',

  -- ========== 结算信息 ==========
  `settlement_amount` DECIMAL(12,2) NOT NULL COMMENT '结算金额',
  `fee_amount` DECIMAL(10,2) DEFAULT 0.00 COMMENT '手续费',
  `actual_amount` DECIMAL(12,2) NOT NULL COMMENT '实际到账金额',

  -- ========== 结算状态 ==========
  `settlement_status` VARCHAR(20) NOT NULL DEFAULT 'pending' COMMENT '结算状态：
    - pending: 待结算
    - processing: 结算中
    - completed: 已结算
    - failed: 结算失败',
  `settlement_time` DATETIME COMMENT '结算时间',

  -- ========== 提现信息 ==========
  `withdraw_status` VARCHAR(20) DEFAULT 'not_applied' COMMENT '提现状态：
    - not_applied: 未申请
    - applied: 已申请
    - processing: 处理中
    - completed: 已完成
    - failed: 失败',
  `withdraw_time` DATETIME COMMENT '提现时间',
  `withdraw_amount` DECIMAL(12,2) COMMENT '提现金额',

  -- ========== 银行信息 ==========
  `bank_account_name` VARCHAR(100) COMMENT '银行账户名',
  `bank_account_number` VARCHAR(50) COMMENT '银行账号',
  `bank_name` VARCHAR(100) COMMENT '开户银行',

  -- ========== 时间信息 ==========
  `create_time` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `update_time` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',

  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_statement_no` (`statement_no`),
  KEY `idx_merchant_id` (`merchant_id`),
  KEY `idx_settlement_cycle` (`settlement_cycle`),
  KEY `idx_start_date` (`start_date`),
  KEY `idx_end_date` (`end_date`),
  KEY `idx_settlement_status` (`settlement_status`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='结算单据表';
```

