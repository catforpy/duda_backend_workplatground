```sql
CREATE TABLE `settlement_statements` (
  -- ========== 主键 ==========
  `id` BIGINT NOT NULL COMMENT '结算单ID（雪花算法）',
  `statement_no` VARCHAR(50) NOT NULL COMMENT '结算单号

