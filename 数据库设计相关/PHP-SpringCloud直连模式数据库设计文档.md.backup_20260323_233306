  -- ========== 微信信息 ==========
  `wechat_unionid` VARCHAR(100) COMMENT '微信UnionID（微信开放平台唯一标识）',
  `wechat_nickname` VARCHAR(100) COMMENT '微信昵称',
  `wechat_avatar` VARCHAR(500) COMMENT '微信头像URL',

  -- ========== 账号状态 ==========
  `user_type` VARCHAR(20) NOT NULL DEFAULT 'platform_user' COMMENT '用户类型：
    - platform_user: 平台用户（普通消费者）
    - merchant_admin: 商户管理员
    - service_provider_admin: 服务商管理员
    - platform_admin: 平台管理员
    - super_admin: 超级管理员',
