  {
    "page": "/pages/order/detail?orderId=xxx",
    "miniprogram_state": "formal",
    "lang": "zh_CN"
  }',

  -- ========== 关联业务 ==========
  `business_type` VARCHAR(50) COMMENT '业务类型：
    - order: 订单相关
    - payment: 支付相关
    - refund: 退款相关
    - activity: 活动相关',
  `business_id` BIGINT COMMENT '业务ID（订单ID、支付ID等）',

  -- ========== 推送状态 ==========
  `push_status` VARCHAR(20) NOT NULL DEFAULT 'pending' COMMENT '推送状态：
    - pending: 待推送
    - sending: 推送中
    - success: 推送成功
    - failed: 推送失败',
  `push_result` VARCHAR(500) COMMENT '推送结果（微信返回信息）',
  `err_code` VARCHAR(50) COMMENT '错误码',
  `err_msg` VARCHAR(500) COMMENT '错误信息',

  -- ========== 重试信息 ==========
  `retry_count` INT DEFAULT 0 COMMENT '重试次数',
  `max_retry` INT DEFAULT 3 COMMENT '最大重试次数',
  `next_retry_time` DATETIME COMMENT '下次重试时间',

  -- ========== 微信返回 ==========
  `wechat_msg_id` BIGINT COMMENT '微信消息ID',
  `wechat_response` JSON COMMENT '微信完整响应（JSON格式）',

  -- ========== 时间信息 ==========
  `create_time` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `send_time` DATETIME COMMENT '发送时间',
  `success_time` DATETIME COMMENT '成功时间',

  PRIMARY KEY (`id`),
  KEY `idx_merchant_id` (`merchant_id`),
  KEY `idx_template_id` (`template_id`),
  KEY `idx_openid` (`openid`),
  KEY `idx_push_status` (`push_status`),
  KEY `idx_create_time` (`create_time`),
  KEY `idx_next_retry_time` (`next_retry_time`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='微信消息推送记录表';
```

**微信消息推送流程**：

```
【触发场景】订单支付成功
    ↓
【后端】判断是否需要推送模板消息
    IF (商户启用了"订单支付成功通知") {
        查询模板：wechat_message_templates
    }
    ↓
【后端】准备推送数据
    1. 获取用户OpenID
       SELECT openid FROM user_wechat_binding 
       WHERE user_id = ? AND mini_program_id = ?

    2. 准备模板数据
       {
         "thing1": {"value": "订单编号ORD202603230001"},
         "amount1": {"value": "85.00元"},
         "date2": {"value": "2026-03-23 15:30:00"}
       }

    3. 创建推送记录
       INSERT INTO wechat_push_logs (
         merchant_id, template_id, openid, 
         push_data, push_status
       ) VALUES (...)
    ↓
【后端】调用微信推送接口
    POST https://api.weixin.qq.com/cgi-bin/message/wxopen/template/send
    {
      "touser": "oAAAAA_xxxxx",
      "template_id": "AT0002",
      "page": "/pages/order/detail?orderId=xxx",
      "data": {...}
    }
    ↓
【微信】推送成功
    返回：{"errcode": 0, "errmsg": "ok", "msgid": 123456789}
    ↓
【后端】更新推送记录
    UPDATE wechat_push_logs
    SET push_status = 'success',
        wechat_msg_id = 123456789,
        wechat_response = '{...}'
    WHERE id = ?
```

