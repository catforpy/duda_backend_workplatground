  `return_msg` VARCHAR(500) COMMENT '返回信息',
  `result_code` VARCHAR(20) COMMENT '业务结果：SUCCESS/FAIL',
  `err_code` VARCHAR(50) COMMENT '错误代码',
  `err_code_des` VARCHAR(500) COMMENT '错误代码描述',
  `wechat_response` JSON COMMENT '微信完整响应（JSON格式）',

  -- ========== 附加信息 ==========
