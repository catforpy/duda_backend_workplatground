  `goods_tag` VARCHAR(200) COMMENT '商品标记',
  `device_info` VARCHAR(100) COMMENT '设备号',

  -- ========== 时间信息 ==========
  `create_time` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `update_time` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',

  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_payment_order_id` (`payment_order_id`),
  UNIQUE KEY `uk_transaction_id` (`transaction_id`),
  KEY `idx_merchant_id` (`merchant_id`),
  KEY `idx_merchant_user_id` (`merchant_user_id`),
  KEY `idx_openid` (`openid`),
  KEY `idx_trade_state` (`trade_state`),
  KEY `idx_time_pay` (`time_pay`),
  KEY `idx_wechat_order_no` (`wechat_order_no`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='微信支付订单表';
```

**微信支付流程**：

```
【前端】用户点击"去支付"
    ↓
【小程序】调用 wx.cloud.callFunction({
  name: 'createPayment',
  data: { orderId: 'ORD202603230001' }
})
    ↓
【后端】SpringCloud处理
    ├─ 1. 查询订单信息
    │   SELECT * FROM payment_orders WHERE order_no = 'ORD202603230001'
    │
    ├─ 2. 获取用户OpenID
    │   SELECT openid FROM user_wechat_binding 
    │   WHERE user_id = ? AND mini_program_id = ?
    │   从openid_list中提取对应小程序的OpenID
    │
    ├─ 3. 获取微信支付配置
    │   SELECT * FROM wechat_payment_config 
    │   WHERE merchant_id = ? AND mini_program_id = ?
    │
    ├─ 4. 调用微信统一下单接口
    │   POST https://api.mch.weixin.qq.com/pay/unifiedorder
    │   返回：prepay_id
    │
    ├─ 5. 创建微信支付订单记录
    │   INSERT INTO wechat_payment_orders (
    │     payment_order_id, openid, prepay_id, ...
    │   )
    │
    └─ 6. 返回支付参数给前端
        { timeStamp, nonceStr, package, signType, paySign }
    ↓
【小程序】调用 wx.requestPayment({
  timeStamp: '',
  nonceStr: '',
  package: '',
  signType: 'MD5',
  paySign: ''
})
    ↓
【用户】输入密码/指纹确认支付
    ↓
【微信】支付成功，异步通知
    ↓
【后端】接收微信支付回调
    POST /api/payment/wechat/notify
    ├─ 验证签名
    ├─ 更新wechat_payment_orders状态
    │   UPDATE wechat_payment_orders 
    │   SET trade_state = 'SUCCESS', 
    │       transaction_id = '微信返回的交易号'
    │   WHERE prepay_id = ?
    ├─ 更新payment_orders状态
    │   UPDATE payment_orders 
    │   SET payment_status = 'paid'
    │   WHERE id = ?
    ├─ 触发自动分账
    │   计算平台抽成、服务商抽成、商户收入
    └─ 返回成功给微信
```

