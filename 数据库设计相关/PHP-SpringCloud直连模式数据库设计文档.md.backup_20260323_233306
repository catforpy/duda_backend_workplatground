**merchant_user_id生成规则**：
```sql
-- 方式1：使用商户级序列号
DELIMITER $$
CREATE FUNCTION generate_merchant_user_id(p_merchant_id BIGINT)
RETURNS VARCHAR(50)
DETERMINISTIC
BEGIN
  DECLARE v_sequence INT;
  DECLARE v_merchant_user_id VARCHAR(50);

  -- 获取并递增商户用户序号
  UPDATE merchants
  SET user_counter = user_counter + 1
  WHERE id = p_merchant_id;

  SELECT user_counter INTO v_sequence
  FROM merchants
  WHERE id = p_merchant_id;

  -- 生成merchant_user_id
  SET v_merchant_user_id = CONCAT('M', p_merchant_id, '_', LPAD(v_sequence, 3, '0'));

  RETURN v_merchant_user_id;
END$$
DELIMITER ;

-- 使用示例
SELECT generate_merchant_user_id(5001);
-- 结果：M5001_001
```

