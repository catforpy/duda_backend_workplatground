      'appid', 'wxaaaa1111',
      'openid', 'oAAAAA_xxxxx',
      'mini_program_id', 2001,
      'merchant_user_id', 'M5001_001',
      'bind_time', '2026-03-23 10:00:00'
    )
  )
);

-- ========== 同一用户授权小程序B（更新openid_list）==========
UPDATE user_wechat_binding
SET openid_list = JSON_SET(
  openid_list,
  '$.wxbbbb2222',
  JSON_OBJECT(
    'appid', 'wxbbbb2222',
    'openid', 'oBBBBB_yyyyy',
    'mini_program_id', 2002,
    'merchant_user_id', 'M5002_005',
    'bind_time', '2026-03-23 14:00:00'
  )
)
WHERE wechat_unionid = 'oUUUUU_12345';

-- ========== 查询用户在某个小程序的OpenID ==========
SELECT 
  JSON_UNQUOTE(
    JSON_EXTRACT(openid_list, '$.wxaaaa1111.openid')
  ) AS openid
FROM user_wechat_binding
WHERE wechat_unionid = 'oUUUUU_12345';
-- 结果：oAAAAA_xxxxx
```

